{
  "name": "stimli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspace stimli-frontend",
    "dev:frontend": "npm run dev --workspace stimli-frontend",
    "dev:pages": "npx wrangler pages dev frontend/dist --compatibility-flag=nodejs_compat --port=8788",
    "deploy:pages": "npm run build && npx wrangler pages deploy frontend/dist --project-name=stimli --branch=main",
    "test": "npm run test:api && npm run test:web && npm run build",
    "test:api": "node --test tests/**/*.test.js",
    "test:web": "npm run test --workspace stimli-frontend"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@simplewebauthn/server": "^13.3.0",
    "stripe": "^22.1.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.3"
  },
  "devDependencies": {
    "wrangler": "^4.92.0"
  }
}
