# Free-tier Stimli profile (Cloudflare Pages production).
# Copy only the values you need into Pages → Settings → Environment Variables,
# or a local .dev.vars file for `wrangler pages dev`. Do not commit real secrets.

# Pages app origin settings.
STIMLI_APP_URL=https://stimli.pages.dev
STIMLI_ORIGIN=https://stimli.pages.dev

# Clerk authentication. Get keys from https://dashboard.clerk.com → API Keys.
# CLERK_SECRET_KEY is a runtime secret (Cloudflare Pages → Settings → Variables).
# VITE_CLERK_PUBLISHABLE_KEY is read at build time by Vite and baked into the
# bundle (set as a GitHub Actions secret so the deploy workflow can read it).
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_AUTHORIZED_PARTIES=https://stimli.pages.dev,http://localhost:5173

# Free database path. Use Neon Postgres (HTTP transport via
# @neondatabase/serverless), provisioned through the Neon dashboard or the
# Cloudflare integration. Without POSTGRES_URL the store falls back to
# in-memory state for local dev / tests.
# POSTGRES_URL=

# Free-first public quotas. Raise only after checking current free-tier usage.
STIMLI_ASSET_LIMIT_PER_HOUR=40
STIMLI_COMPARISON_LIMIT_PER_HOUR=12
STIMLI_MAX_DIRECT_UPLOAD_BYTES=26214400
STIMLI_MAX_INLINE_FILE_BYTES=8388608
STIMLI_COMPARISON_JOB_TIMEOUT_MS=900000
STIMLI_RETENTION_DAYS=365
STIMLI_SHARE_LINK_TTL_DAYS=14

# Free-first hosted inference. Modal Starter has monthly free compute credits;
# keep concurrency low and containers quick to scale down.
STIMLI_BRAIN_PROVIDER=tribe-remote
TRIBE_INFERENCE_URL=
TRIBE_CONTROL_URL=
STIMLI_EXTRACT_URL=
TRIBE_API_KEY=
STIMLI_MODAL_MAX_CONTAINERS=1
STIMLI_MODAL_SCALEDOWN_WINDOW=60
STIMLI_EXTRACT_SCALEDOWN_WINDOW=30

# Billing stays disabled on the free profile.
# Stripe has no monthly platform fee — only per-transaction processing fees on
# real customer charges (2.9% + 30¢ at typical US rates). Test mode is free,
# so the entire flow can run without any spend until live customers exist.
# STRIPE_SECRET_KEY=
# STRIPE_GROWTH_PRICE_ID=
# STRIPE_SCALE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=
# STIMLI_TRIBE_COMMERCIAL_LICENSE=0

# Optional plan overrides. The catalog in functions/api/_lib/billing.js carries
# sane defaults; set these to tune limits or prices without a redeploy.
# STIMLI_RESEARCH_COMPARISON_LIMIT_PER_MONTH=25
# STIMLI_RESEARCH_ASSET_LIMIT_PER_MONTH=200
# STIMLI_GROWTH_PRICE_CENTS_MONTHLY=14900
# STIMLI_GROWTH_COMPARISON_LIMIT_PER_MONTH=500
# STIMLI_GROWTH_ASSET_LIMIT_PER_MONTH=4000
# STIMLI_SCALE_PRICE_CENTS_MONTHLY=49900
# STIMLI_SCALE_COMPARISON_LIMIT_PER_MONTH=5000
# STIMLI_SCALE_ASSET_LIMIT_PER_MONTH=40000
